# Server
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# MongoDB
MONGO_URI=mongodb://localhost:27017/bugsense

# Auth
JWT_SECRET=replace_with_a_long_random_string
JWT_EXPIRES_IN=7d

# Qdrant (vector DB) — https://cloud.qdrant.io
QDRANT_URL=https://your-cluster.qdrant.io
QDRANT_API_KEY=your_qdrant_api_key
QDRANT_COLLECTION=bugsense_bugs

# LLM — Groq (llama-3.1-8b-instant) — https://console.groq.com
GROQ_API_KEY=your_groq_api_key

# Embeddings — Google Gemini (gemini-embedding-001) — https://aistudio.google.com
GEMINI_API_KEY=your_gemini_api_key
